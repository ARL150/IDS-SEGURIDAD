# =============================================
# IDS INSTITUCIONAL - Configuración de entorno
# Copiar como .env y completar los valores
# =============================================

# Correo del administrador (destinatario de alertas)
ADMIN_EMAIL=admin@empresa.com

# Configuración SMTP para envío de alertas
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ids-alertas@empresa.com
SMTP_PASSWORD=tu_contrasena_de_aplicacion

# Interfaz de red a monitorear (ej: eth0, wlan0, en0)
NETWORK_INTERFACE=en0

# Clave secreta para la API (autenticación básica)
API_SECRET_KEY=cambia_esta_clave_secreta_32chars

# Puerto del servidor backend
BACKEND_PORT=8000

# URL del servicio AbuseIPDB (Threat Intelligence)
ABUSEIPDB_API_KEY=tu_api_key_de_abuseipdb

# Intervalo de reporte de dominios en segundos
REPORT_INTERVAL=300
